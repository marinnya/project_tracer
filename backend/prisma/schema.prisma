generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

model Project {
  id                Int       @id @default(autoincrement())
  oneCId            String?   @unique // Индекс для быстрой синхронизации
  name              String
  startDate         DateTime?
  endDate           DateTime?
  status            String    @default("В работе")
  
  // Ответственный
  oneCResponsibleId String?   // ID сотрудника в 1С
  responsibleId     String?   // Ссылка на ID нашей таблицы User
  responsibleUser   User?     @relation(fields: [responsibleId], references: [id])

  archivedAt        DateTime?
  folderUrl         String?
  createdAt         DateTime  @default(now())

  // Связи
  photos            ProjectPhoto[]
  defects           Defect[]
  draft             ProjectDraft?

  @@index([oneCId])
}

model User {
  id           String    @id @default(uuid())
  oneCId       String?   @unique
  firstName    String
  lastName     String
  login        String    @unique
  passwordHash String
  role         Role      @default(EMPLOYEE)
  isBlocked    Boolean   @default(false)
  email        String?   @unique
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  projects            Project[]
  passwordResetTokens PasswordResetToken[]

  @@index([oneCId])
}

model DefectType {
  id      Int      @id @default(autoincrement())
  oneCId  String   @unique
  name    String
  defects Defect[]
}

model Defect {
  id        Int    @id @default(autoincrement())
  projectId Int
  typeId    Int    // Ссылка на DefectType
  pages     Int

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defectType DefectType   @relation(fields: [typeId], references: [id])
  photos     ProjectPhoto[]
}

model ProjectPhoto {
  id           Int      @id @default(autoincrement())
  projectId    Int
  defectId     Int?
  section      String?
  originalName String
  filename     String?
  yandexPath   String?
  order        Int
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defect  Defect? @relation(fields: [defectId], references: [id], onDelete: Cascade)
}

model ProjectDraft {
  id        Int      @id @default(autoincrement())
  projectId Int      @unique
  sections  Json
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}