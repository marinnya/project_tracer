generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

model Project {
  id                Int       @id @default(autoincrement())
  name              String
  startDate         DateTime?
  endDate           DateTime?
  responsible       String
  responsibleId     String?
  oneCResponsibleId String?
  oneCId            String?   @unique
  status            String    @default("В работе")
  archivedAt        DateTime?
  folderUrl         String?
  createdAt         DateTime  @default(now())

  photos          ProjectPhoto[]
  draft           ProjectDraft?
  defects         Defect[]
  responsibleUser User?   @relation(fields: [responsibleId], references: [id])
}

model User {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  login        String    @unique
  passwordHash String
  oneCId       String?   @unique
  role         Role      @default(EMPLOYEE)
  isBlocked    Boolean   @default(false)
  email        String?   @unique
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  passwordResetTokens PasswordResetToken[]
  projects            Project[]
}

model Defect {
  id        Int    @id @default(autoincrement())
  projectId Int
  typeId    Int    // id типа дефекта из справочника
  typeName  String // название типа — для отображения
  pages     Int    // количество страниц

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  photos  ProjectPhoto[]
}

model ProjectPhoto {
  id           Int      @id @default(autoincrement())
  projectId    Int
  section      String?  // для обычных секций
  defectId     Int?     // для фото дефектов
  originalName String
  filename     String?
  yandexPath   String?
  order        Int
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defect  Defect? @relation(fields: [defectId], references: [id], onDelete: Cascade)
}

model ProjectDraft {
  id        Int      @id @default(autoincrement())
  projectId Int      @unique
  sections  Json
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}